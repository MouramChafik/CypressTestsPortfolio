    "cy:run:about": "cypress run --spec 'cypress/e2e/03_about.cy.js'",
    "cy:run:skills": "cypress run --spec 'cypress/e2e/04_skills.cy.js'",
    "cy:run:projects": "cypress run --spec 'cypress/e2e/05_projects.cy.js'",
    "cy:run:contact": "cypress run --spec 'cypress/e2e/06_contact.cy.js'",
    "cy:run:responsive": "cypress run --spec 'cypress/e2e/07_responsive.cy.js'",
    "cy:run:accessibility": "cypress run --spec 'cypress/e2e/08_accessibility.cy.js'"
